# Django Settings
DEBUG=False
SECRET_KEY=your_very_long_random_string_here
ALLOWED_HOSTS='127.0.0.1'
SECURE_SSL_REDIRECT=True

# Database
DB_ENGINE=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Postgres Image Settings (for the db container)]p\
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Site ID
SITE_ID=1

# Superuser (For auto-creation on deploy)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=your_secure_password

# Cloudflare R2
CF_R2_ACCOUNT_ID=your_account_id
CF_R2_ACCESS_KEY_ID=your_r2_access_key_id
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CF_R2_BUCKET_NAME=puconnect-media
CF_R2_PUBLIC_URL=https://your-bucket.your-subdomain.r2.dev

# Web Push VAPID keys — generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('VAPID_PUBLIC_KEY='+v.public_key.decode()); print('VAPID_PRIVATE_KEY='+v.private_key.decode())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=puconnect1@gmail.com